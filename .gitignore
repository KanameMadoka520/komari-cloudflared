# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
__debug*

# local development data
komari.db
/data
/utils/geoip/data
.vscode/
/backup

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env
.env.local
.env.development
.env.production

# build
komari

# frontend workspace
/frontend/komari-web/node_modules/
/frontend/komari-web/dist/
/frontend/komari-web/.vite/
/frontend/komari-web/.env.local
/frontend/komari-web/.env.development
/frontend/komari-web/.env.development.local
/frontend/komari-web/.env.production.local
/frontend/komari-web/.env.test.local
/frontend/komari-web/bundle-analysis.html

# docker runtime if kept inside the repo in the future
/docker/.env
/docker/data/
/docker/reference-media/
